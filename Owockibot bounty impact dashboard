<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>owockibot — Bounty Ledger</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#0B1220;
    --panel:#111B2E;
    --panel-2:#0E1626;
    --line: rgba(237,239,243,0.09);
    --line-strong: rgba(237,239,243,0.16);
    --text:#EDEFF3;
    --dim:#8792A3;
    --amber:#E3A857;
    --amber-dim: rgba(227,168,87,0.18);
    --teal:#4FD1C5;
    --teal-dim: rgba(79,209,197,0.16);
    --rose:#E2725B;
    --rose-dim: rgba(226,114,91,0.16);
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;background:var(--ink);color:var(--text);font-family:'Space Grotesk',sans-serif;}
  ::selection{background:var(--amber-dim);color:var(--text);}

  .mono{font-family:'JetBrains Mono',monospace;}

  .wrap{max-width:1080px;margin:0 auto;padding:0 24px 120px;}

  /* HERO */
  .hero{
    padding:72px 24px 56px;
    border-bottom:1px solid var(--line);
    background:
      radial-gradient(600px 300px at 15% 0%, rgba(227,168,87,0.08), transparent 60%),
      radial-gradient(500px 260px at 90% 10%, rgba(79,209,197,0.06), transparent 60%);
  }
  .hero-inner{max-width:1080px;margin:0 auto;}
  .eyebrow{
    font-family:'JetBrains Mono',monospace;
    font-size:12px; letter-spacing:.14em; text-transform:uppercase;
    color:var(--amber); display:flex; align-items:center; gap:10px; margin-bottom:22px;
  }
  .eyebrow::before{content:"";width:7px;height:7px;border-radius:50%;background:var(--amber);box-shadow:0 0 0 4px var(--amber-dim);}
  h1{
    font-size:clamp(32px,5vw,52px); line-height:1.05; margin:0 0 14px; font-weight:700;
    letter-spacing:-0.01em;
  }
  .hero-sub{color:var(--dim); font-size:16px; max-width:560px; line-height:1.55; margin:0 0 40px;}

  .hero-stat{
    display:flex; align-items:baseline; gap:16px; flex-wrap:wrap;
  }
  .hero-number{font-family:'JetBrains Mono',monospace; font-size:clamp(40px,7vw,72px); font-weight:700; color:var(--amber); letter-spacing:-0.02em;}
  .hero-number small{font-size:0.4em; color:var(--dim); font-weight:500; margin-left:6px;}
  .hero-caption{color:var(--dim); font-size:13px; font-family:'JetBrains Mono',monospace;}

  .kpi-row{display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background:var(--line); margin-top:44px; border:1px solid var(--line);}
  .kpi{background:var(--panel); padding:20px 18px;}
  .kpi-label{font-size:11px; text-transform:uppercase; letter-spacing:.1em; color:var(--dim); font-family:'JetBrains Mono',monospace; margin-bottom:8px;}
  .kpi-value{font-family:'JetBrains Mono',monospace; font-size:26px; font-weight:700;}
  .kpi-value.amber{color:var(--amber);} .kpi-value.teal{color:var(--teal);} .kpi-value.rose{color:var(--rose);}

  /* SECTIONS */
  section{padding:56px 0; border-bottom:1px solid var(--line);}
  .section-head{display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:28px; gap:16px; flex-wrap:wrap;}
  .section-title{font-size:22px; font-weight:600; margin:0;}
  .section-note{color:var(--dim); font-size:13px; font-family:'JetBrains Mono',monospace;}

  /* CATEGORY BARS */
  .cat-list{display:flex; flex-direction:column; gap:14px;}
  .cat-row{display:grid; grid-template-columns:130px 1fr 90px; align-items:center; gap:16px;}
  .cat-name{font-size:14px; font-weight:600;}
  .cat-track{height:10px; background:var(--panel-2); border:1px solid var(--line); position:relative; overflow:hidden;}
  .cat-fill{height:100%; border-radius:0;}
  .cat-count{font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--dim); text-align:right;}

  /* MONTHLY TREND */
  .trend{display:flex; align-items:flex-end; gap:10px; height:180px; padding-top:20px; border-bottom:1px solid var(--line-strong);}
  .trend-col{flex:1; display:flex; flex-direction:column; align-items:center; justify-content:flex-end; height:100%; gap:8px; cursor:default;}
  .trend-bar{width:100%; max-width:44px; background:linear-gradient(180deg, var(--amber), rgba(227,168,87,0.35)); position:relative; transition:opacity .15s;}
  .trend-col:hover .trend-bar{opacity:0.75;}
  .trend-val{font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--amber);}
  .trend-labels{display:flex; gap:10px; margin-top:10px;}
  .trend-label{flex:1; text-align:center; font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--dim);}

  /* LEDGER / TOP CONTRIBUTORS */
  .ledger{border:1px solid var(--line); background:var(--panel);}
  .ledger-row{
    display:grid; grid-template-columns:44px 1fr 100px 90px; gap:14px; align-items:center;
    padding:14px 18px; border-bottom:1px dashed var(--line);
  }
  .ledger-row:last-child{border-bottom:none;}
  .ledger-row.head{
    font-family:'JetBrains Mono',monospace; font-size:11px; text-transform:uppercase; letter-spacing:.08em; color:var(--dim);
    border-bottom:1px solid var(--line-strong);
  }
  .rank{font-family:'JetBrains Mono',monospace; color:var(--amber); font-size:13px;}
  .builder-addr{font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--text);}
  .builder-bar-wrap{grid-column:1 / -1; height:4px; background:var(--panel-2); margin-top:10px; overflow:hidden;}
  .builder-bar{height:100%; background:var(--amber);}
  .ledger-count{font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--dim); text-align:right;}
  .ledger-amt{font-family:'JetBrains Mono',monospace; font-size:14px; color:var(--teal); font-weight:600; text-align:right;}

  /* STATUS PILLS */
  .status-strip{display:flex; gap:1px; height:28px; border:1px solid var(--line); overflow:hidden; margin-bottom:10px;}
  .status-seg{height:100%;}
  .status-legend{display:flex; gap:22px; flex-wrap:wrap; font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--dim);}
  .legend-dot{display:inline-block; width:8px; height:8px; margin-right:6px; border-radius:1px; vertical-align:middle;}

  footer{padding:40px 0 0; text-align:center; color:var(--dim); font-size:12px; font-family:'JetBrains Mono',monospace;}
  footer a{color:var(--amber); text-decoration:none;}

  .loading, .err{padding:80px 24px; text-align:center; color:var(--dim); font-family:'JetBrains Mono',monospace;}
  .err{color:var(--rose);}

  @media (max-width:640px){
    .kpi-row{grid-template-columns:repeat(2,1fr);}
    .ledger-row{grid-template-columns:32px 1fr 70px; }
    .ledger-row > .ledger-amt{display:none;}
    .ledger-row.head > div:nth-child(4){display:none;}
    .cat-row{grid-template-columns:90px 1fr 60px;}
  }
</style>
</head>
<body>

<div id="app">
  <div class="loading">loading bounty ledger from owockibot.xyz…</div>
</div>

<script>
const API = 'https://www.owockibot.xyz/api/bounty-board';
const CORS_PROXIES = [
  'https://corsproxy.io/?url=',
  'https://api.allorigins.win/raw?url='
];

function fmtUSD(n){ return '$' + Math.round(n).toLocaleString('en-US'); }
function shortAddr(a){ return a ? (a.slice(0,6) + '…' + a.slice(-4)) : '—'; }
function monthKey(iso){ const d = new Date(iso); return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0'); }
function monthLabel(key){
  const [y,m] = key.split('-');
  return new Date(y, m-1, 1).toLocaleString('en-US', {month:'short'});
}

function classify(title){
  const t = (title || '').toLowerCase();
  if (t.includes('bug bounty')) return 'Bug';
  if (t.includes('x thread')) return 'Thread';
  if (t.includes('best content')) return 'Content';
  return 'Project';
}

const CAT_COLOR = {
  Bug:'#E2725B', Thread:'#4FD1C5', Content:'#E3A857', Project:'#8792A3'
};
const STATUS_COLOR = {
  completed:'#4FD1C5', claimed:'#E3A857', cancelled:'#E2725B', open:'#8792A3'
};

async function tryFetch(url){
  const res = await fetch(url, { headers:{'Accept':'application/json'} });
  if(!res.ok) throw new Error('bad status ' + res.status);
  const data = await res.json();
  if(!Array.isArray(data) || data.length === 0) throw new Error('empty payload');
  return data;
}

async function load(){
  const attempts = [API, ...CORS_PROXIES.map(p => p + encodeURIComponent(API))];
  let lastErr;
  for(const url of attempts){
    try{
      const data = await tryFetch(url);
      render(data);
      return;
    }catch(e){
      lastErr = e;
    }
  }
  document.getElementById('app').innerHTML =
    '<div class="err">Could not reach the bounty board API right now — direct request and both CORS-proxy fallbacks failed (' +
    (lastErr && lastErr.message ? lastErr.message : 'network error') +
    ').<br><br>This page only ever shows real, live data — it will never display fabricated numbers. ' +
    'Try reloading, or open <a href="' + API + '" target="_blank" style="color:var(--amber)">the raw API</a> directly to confirm the board is reachable.</div>';
}

function render(all){
  // sanitize: valid reward, valid status
  const bounties = all.filter(b => typeof b.reward_usdc === 'number' && b.reward_usdc > 0 && b.reward_usdc < 100000);

  const completed = bounties.filter(b => b.status === 'completed');
  const totalPaid = completed.reduce((s,b) => s + b.reward_usdc, 0);

  const builderSet = new Set();
  bounties.forEach(b => { if (b.claimer_address) builderSet.add(b.claimer_address.toLowerCase()); });

  // category breakdown (all non-cancelled-test bounties, by count)
  const catCounts = {};
  bounties.forEach(b => {
    const c = classify(b.title);
    catCounts[c] = (catCounts[c]||0) + 1;
  });
  const catTotal = Object.values(catCounts).reduce((a,b)=>a+b,0);
  const catOrder = ['Bug','Thread','Content','Project'].filter(c => catCounts[c]);

  // status breakdown
  const statusCounts = {};
  bounties.forEach(b => { statusCounts[b.status] = (statusCounts[b.status]||0) + 1; });
  const statusTotal = bounties.length;

  // monthly trend (completed payouts by month, last 6 months present in data)
  const monthly = {};
  completed.forEach(b => {
    const k = monthKey(b.updated_at || b.created_at);
    monthly[k] = (monthly[k]||0) + b.reward_usdc;
  });
  const monthKeys = Object.keys(monthly).sort().slice(-6);
  const maxMonth = Math.max(...monthKeys.map(k => monthly[k]), 1);

  // top contributors by completed earnings
  const earnings = {};
  const counts = {};
  completed.forEach(b => {
    if(!b.claimer_address) return;
    const a = b.claimer_address.toLowerCase();
    earnings[a] = (earnings[a]||0) + b.reward_usdc;
    counts[a] = (counts[a]||0) + 1;
  });
  const top = Object.entries(earnings).sort((a,b)=>b[1]-a[1]).slice(0,8);
  const maxEarn = top.length ? top[0][1] : 1;

  const html = `
  <div class="hero">
    <div class="hero-inner">
      <div class="eyebrow">owockibot · bounty board · live ledger</div>
      <h1>What actually got built.</h1>
      <p class="hero-sub">Every payout, every builder, every bounty — pulled live from the owockibot bounty board API. No self-reported stats, just the ledger.</p>
      <div class="hero-stat">
        <div class="hero-number">${fmtUSD(totalPaid)}<small>USDC paid out</small></div>
      </div>
      <div class="hero-caption">across ${completed.length} completed bounties</div>

      <div class="kpi-row">
        <div class="kpi">
          <div class="kpi-label">Unique builders</div>
          <div class="kpi-value amber">${builderSet.size}</div>
        </div>
        <div class="kpi">
          <div class="kpi-label">Total bounties</div>
          <div class="kpi-value">${bounties.length}</div>
        </div>
        <div class="kpi">
          <div class="kpi-label">Completed</div>
          <div class="kpi-value teal">${completed.length}</div>
        </div>
        <div class="kpi">
          <div class="kpi-label">Avg payout</div>
          <div class="kpi-value">${fmtUSD(completed.length ? totalPaid/completed.length : 0)}</div>
        </div>
      </div>
    </div>
  </div>

  <div class="wrap">

    <section>
      <div class="section-head">
        <h2 class="section-title">Bounty status mix</h2>
        <span class="section-note">${statusTotal} total records</span>
      </div>
      <div class="status-strip">
        ${Object.entries(statusCounts).sort((a,b)=>b[1]-a[1]).map(([s,c]) =>
          `<div class="status-seg" style="width:${(c/statusTotal*100).toFixed(2)}%; background:${STATUS_COLOR[s]||'#555'}"></div>`
        ).join('')}
      </div>
      <div class="status-legend">
        ${Object.entries(statusCounts).sort((a,b)=>b[1]-a[1]).map(([s,c]) =>
          `<span><span class="legend-dot" style="background:${STATUS_COLOR[s]||'#555'}"></span>${s} — ${c}</span>`
        ).join('')}
      </div>
    </section>

    <section>
      <div class="section-head">
        <h2 class="section-title">Bounties by category</h2>
        <span class="section-note">bug · content · thread · project</span>
      </div>
      <div class="cat-list">
        ${catOrder.map(c => `
          <div class="cat-row">
            <div class="cat-name">${c}</div>
            <div class="cat-track"><div class="cat-fill" style="width:${(catCounts[c]/catTotal*100).toFixed(1)}%; background:${CAT_COLOR[c]}"></div></div>
            <div class="cat-count">${catCounts[c]} · ${(catCounts[c]/catTotal*100).toFixed(0)}%</div>
          </div>
        `).join('')}
      </div>
    </section>

    <section>
      <div class="section-head">
        <h2 class="section-title">Monthly payout trend</h2>
        <span class="section-note">completed USDC, last ${monthKeys.length} months</span>
      </div>
      <div class="trend">
        ${monthKeys.map(k => `
          <div class="trend-col">
            <div class="trend-val">${fmtUSD(monthly[k])}</div>
            <div class="trend-bar" style="height:${Math.max((monthly[k]/maxMonth*140),4)}px"></div>
          </div>
        `).join('')}
      </div>
      <div class="trend-labels">
        ${monthKeys.map(k => `<div class="trend-label">${monthLabel(k)}</div>`).join('')}
      </div>
    </section>

    <section style="border-bottom:none;">
      <div class="section-head">
        <h2 class="section-title">Top contributors</h2>
        <span class="section-note">ranked by completed USDC earned</span>
      </div>
      <div class="ledger">
        <div class="ledger-row head">
          <div>#</div><div>Builder</div><div>Bounties</div><div>Earned</div>
        </div>
        ${top.map(([addr, amt], i) => `
          <div class="ledger-row">
            <div class="rank">${String(i+1).padStart(2,'0')}</div>
            <div class="builder-addr">${shortAddr(addr)}</div>
            <div class="ledger-count">${counts[addr]}×</div>
            <div class="ledger-amt">${fmtUSD(amt)}</div>
            <div class="builder-bar-wrap"><div class="builder-bar" style="width:${(amt/maxEarn*100).toFixed(1)}%"></div></div>
          </div>
        `).join('')}
      </div>
    </section>

    <footer>
      live from <a href="https://owockibot.xyz/api/bounty-board" target="_blank">owockibot.xyz/api/bounty-board</a> · refreshed on page load
    </footer>
  </div>
  `;

  document.getElementById('app').innerHTML = html;
}

load();
</script>
</body>
</html>
